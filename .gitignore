# Re-include the TypeScript lib/ dir (the Python `lib/` rule above would ignore it)
!/lib/
!/lib/**

# Playwright MCP scratch snapshots
/.playwright-mcp/*.yml
/.playwright-mcp/*.log

# Baseline reference screenshots (large, regenerable from Django); keep the JSON
/baselines/*.png

# Pace classifier raw snapshots (large; regenerable via prepare-pace-sources.ts)
/data/sources/pace/raw/

# Hourly normals station CSVs (~6MB each, ~550MB total; regenerable via
# import-hourly-normals.ts --refresh). The monthly station CSVs are small enough
# to track; these are not.
/data/sources/weather/hourly/

# Air quality importer raw snapshots (regenerable via import-air-quality.ts)
/data/sources/air-quality/*.zip
/data/sources/air-quality/annual_aqi_by_*.csv
/data/sources/air-quality/*Gaz_counties*.txt
